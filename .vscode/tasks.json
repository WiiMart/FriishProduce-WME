{
    "version": "2.0.0",
    "tasks": [
        // 'Workflow' task (require)-> Run (require)-> Compile
        //      So more accurately, main task > compile > run
        //
        // Includes Debug and Release options
//------------------------------------------------------------------------------------>
        {
            "label": "Run FPWME Workflow",
            "type": "shell",
            "command": "echo Finished FriishProduce-WME Workflow.",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "Run FPWME"
        },
//------------------------------------------------------------------------------------>
        {
            "label": "Run FPWME",
            "type": "shell",
            "command": "${workspaceFolder}/FriishProduce/bin/${input:buildConfig}/FriishProduce.exe",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "dependsOn": "Compile FPWME",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": "none"
        },
//------------------------------------------------------------------------------------>
        {
            "label": "Compile FPWME",
            "type": "process",
            // <--------- CHANGE PATH TO MSBUILD.EXE IF NEEDED, WATCH OUT FOR THOSE PESKY ESCAPED QUOTATIONS AND BACKSLASHES ------------------->
            "command": "C:/Program Files (x86)/Microsoft Visual Studio/2022/BuildTools/MSBuild/Current/Bin/MSBuild.exe",
            "args": [
                "${workspaceFolder}/FriishProduce.sln",
                "/t:Build",
                "/p:Configuration=${input:buildConfig}",
                "/p:Platform=Any CPU"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile",
            "group": "none"
        },
//------------------------------------------------------------------------------------>
//          'Test' task below for running without compiling first
//------------------------------------------------------------------------------------>
        {
            "label": "Run FPWME (NRC)",
            "type": "shell",
            "command": "${workspaceFolder}/FriishProduce/bin/${input:buildConfig}/FriishProduce.exe",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": "test"
        }
    ],
    "inputs": [
        {
            "id": "buildConfig",
            "type": "pickString",
            "description": "Choose build configuration",
            "options": [
                "Debug",
                "Release"
            ],
            "default": "Debug"
        }
    ]
}